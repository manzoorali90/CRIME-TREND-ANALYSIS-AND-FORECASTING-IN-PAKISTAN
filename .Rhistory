labs(title = paste0("Linear Trend Regression (R² = ", round(summary(lm_trend)$r.squared,2), ")"),
x = "Month index", y = "Total Crimes")
save_plot(p_reg1, "22_regression_trend")
# 6.2 Multiple regression: Total crime ~ time trend + seasonal month dummies
monthly_totals$MonthFac <- factor(monthly_totals$MonthNum)
lm_seasonal <- lm(Total ~ t + MonthFac, data = monthly_totals)
summary(lm_seasonal)
monthly_totals$fitted_seasonal <- fitted(lm_seasonal)
p_reg2 <- ggplot(monthly_totals, aes(Date)) +
geom_line(aes(y = Total), color = "black") + geom_point(aes(y=Total)) +
geom_line(aes(y = fitted_seasonal), color = "purple", linetype = "dashed", size = 1) +
labs(title = paste0("Trend + Seasonal Regression (R² = ", round(summary(lm_seasonal)$r.squared,2), ")"),
y = "Total Crimes")
save_plot(p_reg2, "23_regression_trend_seasonal")
# 6.3 Model diagnostics
par(mfrow = c(2,2)); plot(lm_seasonal); par(mfrow = c(1,1))
# 7.1 Cluster crime CATEGORIES by their standardized monthly time-series profile
cat_matrix <- t(scale(crime_wide[,-1]))    # rows = categories, cols = months (standardized)
rownames(cat_matrix) <- colnames(crime_wide)[-1]
fviz_nbclust(cat_matrix, kmeans, method = "wss") +
labs(title = "Elbow Method for Optimal k (Category Clustering)")
ggsave("figures/24_elbow_method.png", width = 6, height = 4, dpi = 150)
set.seed(42)
km_cat <- kmeans(cat_matrix, centers = 3, nstart = 25)
print(km_cat$cluster)
p_clust <- fviz_cluster(km_cat, data = cat_matrix, repel = TRUE) +
labs(title = "K-Means Clustering of Crime Categories")
ggsave("figures/25_cluster_pca_scatter.png", plot = p_clust, width = 7, height = 6, dpi = 150)
# 7.2 Cluster MONTHS by their crime profile across categories
month_matrix <- scale(crime_wide[,-1])
rownames(month_matrix) <- as.character(crime_wide$Date)
set.seed(42)
km_month <- kmeans(month_matrix, centers = 3, nstart = 25)
month_cluster_df <- data.frame(Date = crime_wide$Date, Cluster = factor(km_month$cluster))
p_monthclust <- ggplot(month_cluster_df, aes(Date, Cluster, color = Cluster)) +
geom_point(size = 3) + labs(title = "K-Means Clustering of Months by Crime Profile")
save_plot(p_monthclust, "26_month_clusters_timeline", h = 3.5)
write.csv(data.frame(CrimeType = rownames(cat_matrix), Cluster = km_cat$cluster),
"output/category_clusters.csv", row.names = FALSE)
ts_total <- ts(monthly_totals$Total, start = c(2022, 1), frequency = 12)
# 8.1 Classical decomposition (additive)
decomp <- decompose(ts_total, type = "additive")
png("figures/27_ts_decomposition.png", width = 1000, height = 900, res = 150)
plot(decomp)
dev.off()
# 8.2 STL decomposition (robust alternative)
stl_decomp <- stl(ts_total, s.window = "periodic")
plot(stl_decomp)
dev.off()
# 8.3 Stationarity tests
adf.test(ts_total)                 # Augmented Dickey-Fuller
kpss.test(ts_total)                # KPSS
ts_diff <- diff(ts_total, differences = 1)
adf.test(ts_diff)
# 8.4 ACF / PACF
png("figures/29_acf_pacf.png", width = 1000, height = 500, res = 150)
par(mfrow = c(1,2))
Acf(ts_total, main = "ACF - Total Monthly Crimes")
Pacf(ts_total, main = "PACF - Total Monthly Crimes")
dev.off()
par(mfrow = c(1,1))
# 9.1 ETS model (automatically selects best exponential smoothing form)
ets_model <- ets(ts_total)
summary(ets_model)
ets_fc <- forecast(ets_model, h = 12)
png("figures/30_ets_forecast.png", width = 1000, height = 600, res = 150)
plot(ets_fc, main = "12-Month Crime Forecast - ETS")
dev.off()
# 9.2 ARIMA model (auto.arima selects best order incl. seasonal component)
arima_model <- auto.arima(ts_total, seasonal = TRUE, stepwise = FALSE, approximation = FALSE)
summary(arima_model)
arima_fc <- forecast(arima_model, h = 12)
png("figures/31_arima_forecast.png", width = 1000, height = 600, res = 150)
plot(arima_fc, main = "12-Month Crime Forecast - ARIMA")
dev.off()
# 9.3 Residual diagnostics
checkresiduals(ets_model)
checkresiduals(arima_model)
# 9.4 Accuracy comparison (in-sample)
acc_ets   <- accuracy(ets_fc)
acc_arima <- accuracy(arima_fc)
model_comparison <- rbind(ETS = acc_ets[1,c("RMSE","MAE","MAPE")],
ARIMA = acc_arima[1,c("RMSE","MAE","MAPE")])
print(model_comparison)
write.csv(model_comparison, "output/model_comparison.csv")
# 9.5 Combined forecast plot
autoplot(ts_total) +
autolayer(ets_fc$mean, series = "ETS Forecast") +
autolayer(arima_fc$mean, series = "ARIMA Forecast") +
labs(title = "Forecast Comparison: ETS vs ARIMA (12-Month Horizon)",
y = "Total Crimes", x = "Year") +
guides(colour = guide_legend(title = "Model"))
ggsave("figures/32_forecast_comparison.png", width = 10, height = 5, dpi = 150)
forecast_table <- data.frame(
Date = as.character(zoo::as.yearmon(time(ets_fc$mean))),
ETS_Forecast = round(as.numeric(ets_fc$mean)),
ETS_Lo95 = round(ets_fc$lower[,2]), ETS_Hi95 = round(ets_fc$upper[,2]),
ARIMA_Forecast = round(as.numeric(arima_fc$mean)),
ARIMA_Lo95 = round(arima_fc$lower[,2]), ARIMA_Hi95 = round(arima_fc$upper[,2])
)
write.csv(forecast_table, "output/forecast_table.csv", row.names = FALSE)
print(forecast_table)
message("ALL PHASES COMPLETE. Figures in /figures, tables in /output.")
