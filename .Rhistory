# Phase 2  - Data Cleaning
# Phase 3  - Data Transformation
# Phase 4  - Exploratory Data Analysis (20+ graphs)
# Phase 5  - Statistical Analysis
# Phase 6  - Regression Analysis
# Phase 7  - Clustering
# Phase 8  - Time Series Analysis
# Phase 9  - Forecasting (ARIMA & ETS)
# Phase 10 - Report (rendered separately - see report R Markdown / Word file)
###############################################################################
setwd("C:/Users/manzo/Downloads/Crime Mothly Data")
# ---- 0. SETUP ---------------------------------------------------------------
required_pkgs <- c("readxl","dplyr","tidyr","ggplot2","forecast","tseries",
"cluster","factoextra","corrplot","reshape2","scales",
"zoo","gridExtra","knitr")
new_pkgs <- required_pkgs[!(required_pkgs %in% installed.packages()[,"Package"])]
if(length(new_pkgs)) install.packages(new_pkgs, repos = "https://cran.r-project.org")
library(readxl)
library(dplyr)
library(tidyr)
library(ggplot2)
library(forecast)
library(tseries)
library(cluster)
library(factoextra)
library(corrplot)
library(reshape2)
library(scales)
library(zoo)
library(gridExtra)
dir.create("figures", showWarnings = FALSE)
dir.create("output",  showWarnings = FALSE)
theme_set(theme_minimal(base_size = 11))
file_path <- "Moth-wise-Crime-data.xlsx"   # place the raw file in your working directory
raw <- read_excel(file_path, sheet = "Sheet1", col_names = FALSE)
months <- c("January","February","March","April","May","June","July",
"August","September","October","November","December")
parse_crime_sheet <- function(raw) {
records <- list()
current_year <- NA
for (i in seq_len(nrow(raw))) {
row <- raw[i, ]
# Year marker rows have a 4-digit year in column 7 and NA elsewhere
if (!is.na(row[[7]]) && suppressWarnings(!is.na(as.numeric(row[[7]]))) &&
as.numeric(row[[7]]) %in% c(2022, 2023, 2024)) {
current_year <- as.numeric(row[[7]])
next
}
label <- row[[2]]
if (is.na(label) || label %in% c("Year/Month", "Total")) next
if (grepl("^Source", label)) next
vals <- as.numeric(row[3:14])
if (all(is.na(vals))) next
records[[length(records) + 1]] <- data.frame(
Year = current_year, Month = months, CrimeType = trimws(label),
Count = vals, stringsAsFactors = FALSE
)
}
bind_rows(records)
}
crime_long <- parse_crime_sheet(raw)
str(crime_long)
table(crime_long$Year, crime_long$CrimeType)
# 2.1 Structural checks
sum(is.na(crime_long$Count))                 # missing values
sum(duplicated(crime_long[, c("Year","Month","CrimeType")]))  # duplicate rows
# 2.2 Standardise category names (fix inconsistent spelling/spacing)
crime_long <- crime_long %>%
mutate(CrimeType = recode(CrimeType,
"Kidnapping/Abduction" = "Kidnapping/Abduction",
"Cattle theft" = "Cattle Theft",
"Other theft" = "Other Theft"))
# 2.3 Outlier / data-entry-error detection
#     "Other Theft" for April 2022 = 900, far below the ~11,000-13,000 range
#     seen in every neighbouring month for the same category -> flagged as a
#     probable data-entry error and imputed with the mean of March & May 2022.
crime_long <- crime_long %>%
mutate(Month = factor(Month, levels = months, ordered = TRUE)) %>%
arrange(CrimeType, Year, Month)
flag_idx <- with(crime_long, Year == 2022 & Month == "April" & CrimeType == "Other Theft")
crime_long$Count_raw <- crime_long$Count      # keep the untouched original
mar_val <- crime_long$Count[with(crime_long, Year==2022 & Month=="March" & CrimeType=="Other Theft")]
may_val <- crime_long$Count[with(crime_long, Year==2022 & Month=="May"   & CrimeType=="Other Theft")]
crime_long$Count[flag_idx] <- round(mean(c(mar_val, may_val)))
# 2.4 Data-quality note: Robbery jumps sharply from Jan-2023 (2,564) to
#     Feb-2023 (8,227) onward. This persists for the rest of 2023-24 and is
#     consistent with a reporting/classification change rather than a single
#     bad cell, so it is RETAINED as-is but flagged for the report.
crime_long$is_flagged <- flag_idx
write.csv(crime_long, "output/crime_long_clean.csv", row.names = FALSE)
crime_long <- crime_long %>%
mutate(MonthNum = as.integer(Month),
Date = as.Date(paste(Year, MonthNum, "01", sep = "-")))
# 3.1 Core categories present across all three years (used for YoY comparisons)
core_crimes <- c("Murder","Attempted Murder","Kidnapping/Abduction","Dacoity",
"Robbery","Burglary","Cattle Theft","Other Theft","Miscellaneous")
# 3.2 Wide format (category x month) - handy for correlation/clustering
crime_wide <- crime_long %>%
filter(CrimeType %in% core_crimes) %>%
pivot_wider(id_cols = Date, names_from = CrimeType, values_from = Count)
# 3.3 Monthly TOTAL series (sum across all categories reported that month)
monthly_totals <- crime_long %>%
group_by(Date, Year, MonthNum) %>%
summarise(Total = sum(Count), .groups = "drop") %>%
arrange(Date)
# 3.4 Year-over-year category totals & % change
yearly_cat <- crime_long %>%
filter(CrimeType %in% core_crimes) %>%
group_by(Year, CrimeType) %>%
summarise(Total = sum(Count), .groups = "drop") %>%
pivot_wider(names_from = Year, values_from = Total, names_prefix = "Y") %>%
mutate(PctChange_22_24 = round((Y2024 - Y2022) / Y2022 * 100, 1))
write.csv(monthly_totals, "output/monthly_totals.csv", row.names = FALSE)
write.csv(yearly_cat, "output/category_yearly_change.csv", row.names = FALSE)
crime_long <- crime_long %>%
mutate(MonthNum = as.integer(Month),
Date = as.Date(paste(Year, MonthNum, "01", sep = "-")))
write.csv(crime_long, "output/crime_long_clean.csv", row.names = FALSE)
crime_long <- crime_long %>%
mutate(MonthNum = as.integer(Month),
Date = as.Date(paste(Year, MonthNum, "01", sep = "-")))
# 3.1 Core categories present across all three years (used for YoY comparisons)
core_crimes <- c("Murder","Attempted Murder","Kidnapping/Abduction","Dacoity",
"Robbery","Burglary","Cattle Theft","Other Theft","Miscellaneous")
# 3.2 Wide format (category x month) - handy for correlation/clustering
crime_wide <- crime_long %>%
filter(CrimeType %in% core_crimes) %>%
pivot_wider(id_cols = Date, names_from = CrimeType, values_from = Count)
# 3.3 Monthly TOTAL series (sum across all categories reported that month)
monthly_totals <- crime_long %>%
group_by(Date, Year, MonthNum) %>%
summarise(Total = sum(Count), .groups = "drop") %>%
arrange(Date)
# 3.4 Year-over-year category totals & % change
yearly_cat <- crime_long %>%
filter(CrimeType %in% core_crimes) %>%
group_by(Year, CrimeType) %>%
summarise(Total = sum(Count), .groups = "drop") %>%
pivot_wider(names_from = Year, values_from = Total, names_prefix = "Y") %>%
mutate(PctChange_22_24 = round((Y2024 - Y2022) / Y2022 * 100, 1))
write.csv(monthly_totals, "output/monthly_totals.csv", row.names = FALSE)
write.csv(yearly_cat, "output/category_yearly_change.csv", row.names = FALSE)
save_plot <- function(p, name, w = 8, h = 5) {
ggsave(filename = file.path("figures", paste0(name, ".png")),
plot = p, width = w, height = h, dpi = 150)
}
# 1. Total monthly crime trend
p1 <- ggplot(monthly_totals, aes(Date, Total)) +
geom_line(color = "firebrick") + geom_point(color = "firebrick") +
labs(title = "Total Monthly Crimes in Pakistan (2022-2024)", y = "Total Crimes")
save_plot(p1, "01_total_monthly_trend")
# 2. Yearly totals
p2 <- crime_long %>% group_by(Year) %>% summarise(Total = sum(Count)) %>%
ggplot(aes(factor(Year), Total, fill = factor(Year))) + geom_col() +
geom_text(aes(label = comma(Total)), vjust = -0.3) +
labs(title = "Total Crimes by Year", x = "Year") + theme(legend.position = "none")
save_plot(p2, "02_yearly_totals")
# 3. Category totals (horizontal bar)
p3 <- crime_long %>% filter(CrimeType %in% core_crimes) %>%
group_by(CrimeType) %>% summarise(Total = sum(Count)) %>%
ggplot(aes(reorder(CrimeType, Total), Total)) + geom_col(fill = "steelblue") +
coord_flip() + labs(title = "Total Crimes by Category (2022-2024)", x = "")
save_plot(p3, "03_category_totals")
# 4. Category share pie/donut for latest year
p4 <- crime_long %>% filter(Year == 2024) %>% group_by(CrimeType) %>%
summarise(Total = sum(Count)) %>%
ggplot(aes(x = 2, y = Total, fill = CrimeType)) +
geom_col(color = "white") + coord_polar(theta = "y") + xlim(0.5, 2.5) +
labs(title = "Crime Category Share - 2024") + theme_void()
save_plot(p4, "04_category_share_2024", w = 7, h = 7)
# 5. Seasonal boxplot of totals by calendar month
p5 <- monthly_totals %>% mutate(MonthName = factor(month.name[MonthNum], levels = month.name)) %>%
ggplot(aes(MonthName, Total)) + geom_boxplot(fill = "orange", alpha = 0.6) +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(title = "Seasonal Distribution of Total Crime by Month", x = "")
save_plot(p5, "05_seasonality_boxplot")
# 6. Heatmap: Year x Month
p6 <- monthly_totals %>% mutate(MonthName = factor(month.name[MonthNum], levels = month.name)) %>%
ggplot(aes(MonthName, factor(Year), fill = Total)) + geom_tile() +
scale_fill_gradient(low = "yellow", high = "red") +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(title = "Heatmap: Total Crime by Year and Month", x = "", y = "Year")
save_plot(p6, "06_heatmap_year_month")
# 7. Small multiples - trend per crime category
p7 <- crime_long %>% filter(CrimeType %in% core_crimes) %>%
ggplot(aes(Date, Count)) + geom_line(color = "navy") +
facet_wrap(~CrimeType, scales = "free_y") +
labs(title = "Monthly Trend by Crime Category (2022-2024)")
save_plot(p7, "07_small_multiples_trends", w = 11, h = 8)
# 8. Correlation heatmap between categories
corr_mat <- cor(crime_wide[,-1], use = "complete.obs")
png("figures/08_correlation_heatmap.png", width = 900, height = 800, res = 150)
corrplot(corr_mat, method = "color", type = "upper", tl.cex = 0.7,
addCoef.col = "black", number.cex = 0.5,
title = "Correlation Between Crime Categories", mar = c(0,0,2,0))
dev.off()
# 9. YoY % change by category
p9 <- yearly_cat %>%
ggplot(aes(reorder(CrimeType, PctChange_22_24), PctChange_22_24,
fill = PctChange_22_24 > 0)) +
geom_col() + coord_flip() +
scale_fill_manual(values = c("forestgreen","firebrick"), guide = "none") +
labs(title = "% Change in Crime Category: 2022 to 2024", x = "", y = "% Change")
save_plot(p9, "09_yoy_growth")
# 10. Stacked area of category composition
p10 <- crime_long %>% filter(CrimeType %in% core_crimes) %>%
ggplot(aes(Date, Count, fill = CrimeType)) + geom_area(position = "stack") +
labs(title = "Crime Category Composition Over Time")
save_plot(p10, "10_stacked_area", w = 10, h = 5.5)
# 11. Histogram of total monthly crimes
p11 <- ggplot(monthly_totals, aes(Total)) + geom_histogram(bins = 10, fill = "dodgerblue", color = "white") +
labs(title = "Distribution of Total Monthly Crime Counts")
save_plot(p11, "11_histogram_totals")
# 12. Q-Q plot for normality
png("figures/12_qqplot_totals.png", width = 700, height = 700, res = 150)
qqnorm(monthly_totals$Total, main = "Q-Q Plot: Total Monthly Crimes"); qqline(monthly_totals$Total, col = "red")
dev.off()
# 13. Boxplot by category (log scale)
p13 <- crime_long %>% filter(CrimeType %in% core_crimes) %>%
ggplot(aes(reorder(CrimeType, Count, median), Count)) + geom_boxplot(fill = "seagreen", alpha = 0.6) +
scale_y_log10() + coord_flip() +
labs(title = "Distribution of Monthly Counts by Category (log scale)", x = "")
save_plot(p13, "13_boxplot_by_category_log")
# 14. Density plot per selected violent-crime categories
p14 <- crime_long %>% filter(CrimeType %in% c("Murder","Attempted Murder","Dacoity")) %>%
ggplot(aes(Count, fill = CrimeType)) + geom_density(alpha = 0.4) +
labs(title = "Density of Monthly Counts: Murder, Attempted Murder, Dacoity")
save_plot(p14, "14_density_violent_crimes")
# 15. Scatter: Robbery vs Burglary (association between property crimes)
p15 <- crime_wide %>% ggplot(aes(Robbery, Burglary)) + geom_point(color = "purple") +
geom_smooth(method = "lm", se = TRUE, color = "black") +
labs(title = "Robbery vs Burglary (Monthly Counts)")
save_plot(p15, "15_scatter_robbery_burglary")
# 16. Cumulative crime over time
p16 <- monthly_totals %>% arrange(Date) %>% mutate(Cumulative = cumsum(Total)) %>%
ggplot(aes(Date, Cumulative)) + geom_area(fill = "coral", alpha = 0.6) +
labs(title = "Cumulative Total Crimes (2022-2024)", y = "Cumulative Count")
save_plot(p16, "16_cumulative_crime")
# 17. Month-on-month % change in total crime
p17 <- monthly_totals %>% arrange(Date) %>%
mutate(PctChange = (Total - lag(Total)) / lag(Total) * 100) %>%
filter(!is.na(PctChange)) %>%
ggplot(aes(Date, PctChange)) + geom_col(aes(fill = PctChange > 0)) +
scale_fill_manual(values = c("forestgreen","firebrick"), guide = "none") +
labs(title = "Month-on-Month % Change in Total Crime", y = "% Change")
save_plot(p17, "17_mom_pct_change")
# 18. Violent vs property crime comparison over time
p18 <- crime_long %>%
mutate(Group = case_when(
CrimeType %in% c("Murder","Attempted Murder","Kidnapping/Abduction","Dacoity") ~ "Violent",
CrimeType %in% c("Robbery","Burglary","Cattle Theft","Other Theft") ~ "Property",
TRUE ~ "Other")) %>%
filter(Group != "Other") %>%
group_by(Date, Group) %>% summarise(Count = sum(Count), .groups = "drop") %>%
ggplot(aes(Date, Count, color = Group)) + geom_line(size = 1) +
labs(title = "Violent vs Property Crime Trends")
save_plot(p18, "18_violent_vs_property")
# 19. Top 5 categories ranked, faceted by year
p19 <- crime_long %>% filter(CrimeType %in% core_crimes, CrimeType != "Miscellaneous") %>%
group_by(Year, CrimeType) %>% summarise(Total = sum(Count), .groups = "drop") %>%
group_by(Year) %>% slice_max(Total, n = 5) %>%
ggplot(aes(reorder(CrimeType, Total), Total, fill = CrimeType)) + geom_col(show.legend = FALSE) +
coord_flip() + facet_wrap(~Year, scales = "free_y") +
labs(title = "Top 5 Crime Categories by Year (excl. Miscellaneous)", x = "")
save_plot(p19, "19_top5_by_year", w = 10, h = 5)
# 20. Boxplot comparing years for total monthly crime
p20 <- ggplot(monthly_totals, aes(factor(Year), Total, fill = factor(Year))) +
geom_boxplot() + labs(title = "Distribution of Monthly Totals by Year", x = "Year") +
theme(legend.position = "none")
save_plot(p20, "20_totals_by_year_boxplot")
# 21. Kidnapping & Robbery combined trend with dual axis approximation (faceted instead)
p21 <- crime_long %>% filter(CrimeType %in% c("Kidnapping/Abduction","Robbery")) %>%
ggplot(aes(Date, Count, color = CrimeType)) + geom_line(size = 1) +
labs(title = "Kidnapping/Abduction vs Robbery Trend")
save_plot(p21, "21_kidnapping_vs_robbery")
message("Phase 4 complete: 20+ EDA figures written to /figures")
# 5.1 Descriptive statistics per category
desc_stats <- crime_long %>% filter(CrimeType %in% core_crimes) %>%
group_by(CrimeType) %>%
summarise(Mean = mean(Count), Median = median(Count), SD = sd(Count),
Min = min(Count), Max = max(Count), .groups = "drop")
write.csv(desc_stats, "output/descriptive_stats.csv", row.names = FALSE)
print(desc_stats)
# 5.2 Normality test on total monthly crime series
shapiro.test(monthly_totals$Total)
# 5.3 ANOVA - do mean monthly counts differ across the 7 "core" crime types
#     (Miscellaneous & Other Theft excluded - different order of magnitude)
anova_data <- crime_long %>%
filter(CrimeType %in% c("Murder","Attempted Murder","Kidnapping/Abduction",
"Dacoity","Robbery","Burglary","Cattle Theft"))
anova_res <- aov(Count ~ CrimeType, data = anova_data)
summary(anova_res)
TukeyHSD(anova_res)   # pairwise comparison
# 5.4 Kruskal-Wallis test - is there a significant month-of-year (seasonal) effect?
kruskal.test(Total ~ factor(MonthNum), data = monthly_totals)
# 5.5 Correlation matrix (already computed as corr_mat in Phase 4) + significance
corr_test <- cor.test(crime_wide$Robbery, crime_wide$Burglary)
print(corr_test)
monthly_totals <- monthly_totals %>% arrange(Date) %>% mutate(t = row_number())
# 6.1 Simple linear regression: Total crime ~ time trend
lm_trend <- lm(Total ~ t, data = monthly_totals)
summary(lm_trend)
p_reg1 <- ggplot(monthly_totals, aes(t, Total)) + geom_point() +
geom_smooth(method = "lm", se = TRUE, color = "red") +
labs(title = paste0("Linear Trend Regression (R² = ", round(summary(lm_trend)$r.squared,2), ")"),
x = "Month index", y = "Total Crimes")
save_plot(p_reg1, "22_regression_trend")
# 6.2 Multiple regression: Total crime ~ time trend + seasonal month dummies
monthly_totals$MonthFac <- factor(monthly_totals$MonthNum)
lm_seasonal <- lm(Total ~ t + MonthFac, data = monthly_totals)
summary(lm_seasonal)
monthly_totals$fitted_seasonal <- fitted(lm_seasonal)
p_reg2 <- ggplot(monthly_totals, aes(Date)) +
geom_line(aes(y = Total), color = "black") + geom_point(aes(y=Total)) +
geom_line(aes(y = fitted_seasonal), color = "purple", linetype = "dashed", size = 1) +
labs(title = paste0("Trend + Seasonal Regression (R² = ", round(summary(lm_seasonal)$r.squared,2), ")"),
y = "Total Crimes")
save_plot(p_reg2, "23_regression_trend_seasonal")
# 6.3 Model diagnostics
par(mfrow = c(2,2)); plot(lm_seasonal); par(mfrow = c(1,1))
# 7.1 Cluster crime CATEGORIES by their standardized monthly time-series profile
cat_matrix <- t(scale(crime_wide[,-1]))    # rows = categories, cols = months (standardized)
rownames(cat_matrix) <- colnames(crime_wide)[-1]
fviz_nbclust(cat_matrix, kmeans, method = "wss") +
labs(title = "Elbow Method for Optimal k (Category Clustering)")
ggsave("figures/24_elbow_method.png", width = 6, height = 4, dpi = 150)
set.seed(42)
km_cat <- kmeans(cat_matrix, centers = 3, nstart = 25)
print(km_cat$cluster)
p_clust <- fviz_cluster(km_cat, data = cat_matrix, repel = TRUE) +
labs(title = "K-Means Clustering of Crime Categories")
ggsave("figures/25_cluster_pca_scatter.png", plot = p_clust, width = 7, height = 6, dpi = 150)
# 7.2 Cluster MONTHS by their crime profile across categories
month_matrix <- scale(crime_wide[,-1])
rownames(month_matrix) <- as.character(crime_wide$Date)
set.seed(42)
km_month <- kmeans(month_matrix, centers = 3, nstart = 25)
month_cluster_df <- data.frame(Date = crime_wide$Date, Cluster = factor(km_month$cluster))
p_monthclust <- ggplot(month_cluster_df, aes(Date, Cluster, color = Cluster)) +
geom_point(size = 3) + labs(title = "K-Means Clustering of Months by Crime Profile")
save_plot(p_monthclust, "26_month_clusters_timeline", h = 3.5)
write.csv(data.frame(CrimeType = rownames(cat_matrix), Cluster = km_cat$cluster),
"output/category_clusters.csv", row.names = FALSE)
ts_total <- ts(monthly_totals$Total, start = c(2022, 1), frequency = 12)
# 8.1 Classical decomposition (additive)
decomp <- decompose(ts_total, type = "additive")
png("figures/27_ts_decomposition.png", width = 1000, height = 900, res = 150)
plot(decomp)
dev.off()
# 8.2 STL decomposition (robust alternative)
stl_decomp <- stl(ts_total, s.window = "periodic")
png("figures/28_stl_decomposition.png", width = 1000, height = 900, res = 150)
plot(stl_decomp)
dev.off()
# 8.3 Stationarity tests
adf.test(ts_total)                 # Augmented Dickey-Fuller
kpss.test(ts_total)                # KPSS
ts_diff <- diff(ts_total, differences = 1)
adf.test(ts_diff)
# 8.4 ACF / PACF
png("figures/29_acf_pacf.png", width = 1000, height = 500, res = 150)
par(mfrow = c(1,2))
Acf(ts_total, main = "ACF - Total Monthly Crimes")
Pacf(ts_total, main = "PACF - Total Monthly Crimes")
dev.off()
par(mfrow = c(1,1))
# 9.1 ETS model (automatically selects best exponential smoothing form)
ets_model <- ets(ts_total)
summary(ets_model)
ets_fc <- forecast(ets_model, h = 12)
png("figures/30_ets_forecast.png", width = 1000, height = 600, res = 150)
plot(ets_fc, main = "12-Month Crime Forecast - ETS")
dev.off()
# 9.2 ARIMA model (auto.arima selects best order incl. seasonal component)
arima_model <- auto.arima(ts_total, seasonal = TRUE, stepwise = FALSE, approximation = FALSE)
summary(arima_model)
arima_fc <- forecast(arima_model, h = 12)
png("figures/31_arima_forecast.png", width = 1000, height = 600, res = 150)
plot(arima_fc, main = "12-Month Crime Forecast - ARIMA")
dev.off()
# 9.3 Residual diagnostics
checkresiduals(ets_model)
checkresiduals(arima_model)
# 9.4 Accuracy comparison (in-sample)
acc_ets   <- accuracy(ets_fc)
acc_arima <- accuracy(arima_fc)
model_comparison <- rbind(ETS = acc_ets[1,c("RMSE","MAE","MAPE")],
ARIMA = acc_arima[1,c("RMSE","MAE","MAPE")])
print(model_comparison)
write.csv(model_comparison, "output/model_comparison.csv")
# 9.5 Combined forecast plot
autoplot(ts_total) +
autolayer(ets_fc$mean, series = "ETS Forecast") +
autolayer(arima_fc$mean, series = "ARIMA Forecast") +
labs(title = "Forecast Comparison: ETS vs ARIMA (12-Month Horizon)",
y = "Total Crimes", x = "Year") +
guides(colour = guide_legend(title = "Model"))
ggsave("figures/32_forecast_comparison.png", width = 10, height = 5, dpi = 150)
forecast_table <- data.frame(
Date = as.character(zoo::as.yearmon(time(ets_fc$mean))),
ETS_Forecast = round(as.numeric(ets_fc$mean)),
ETS_Lo95 = round(ets_fc$lower[,2]), ETS_Hi95 = round(ets_fc$upper[,2]),
ARIMA_Forecast = round(as.numeric(arima_fc$mean)),
ARIMA_Lo95 = round(arima_fc$lower[,2]), ARIMA_Hi95 = round(arima_fc$upper[,2])
)
write.csv(forecast_table, "output/forecast_table.csv", row.names = FALSE)
print(forecast_table)
message("ALL PHASES COMPLETE. Figures in /figures, tables in /output.")
